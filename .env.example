# Base URL of the Once API. Leave empty to fall back to the local mock auth
# (useful when no backend is running). No trailing slash.
#
# Local dev:   http://localhost:5051  (matches Once.Api launchSettings.json)
# Stage/prod:  /api                   (proxied by nginx — see deploy/README.md)
VITE_API_BASE_URL=http://localhost:5051

# Optional. Demo-request form on the marketing page. If unset, the form
# short-circuits to a mock success.
# VITE_DEMO_API_URL=
# VITE_DEMO_API_METHOD=POST

# Optional. OAuth/SSO redirect targets (handled by the backend).
# VITE_GOOGLE_OAUTH_URL=/auth/google
# VITE_SSO_INIT_URL=/auth/sso
